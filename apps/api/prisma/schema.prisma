generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PROFESSOR
  ALUNO
}

enum StudentStatus {
  ATIVO
  INATIVO
}

enum InvoiceStatus {
  PAGO
  PENDENTE
  ATRASADO
  CANCELADO
}

enum WorkoutDayLabel {
  A
  B
  C
  D
  E
}

enum PaymentProvider {
  MERCADO_PAGO
  ASAAS
  EFI
}

enum PaymentTransactionStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
  FAILED
}

enum ExerciseMediaType {
  IMAGE
  GIF
  VIDEO
  EXTERNAL_URL
}

model Organization {
  id                 String              @id @default(uuid())
  name               String
  document           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  users              User[]
  students           Student[]
  plans              Plan[]
  financialSettings  FinancialSettings?
  invoices           Invoice[]
  paymentTransactions PaymentTransaction[]
  assessments        PhysicalAssessment[]
  workoutPlans       WorkoutPlan[]
  exerciseLibrary    ExerciseLibrary[]
  auditLogs          AuditLog[]
}

model User {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String       @unique
  passwordHash   String
  role           Role
  isActive       Boolean      @default(true)
  student        Student?
  assessments    PhysicalAssessment[] @relation("ProfessorAssessments")
  workoutPlans   WorkoutPlan[] @relation("ProfessorWorkoutPlans")
  auditLogs      AuditLog[]
  passwordResetTokens PasswordResetToken[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, role])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, usedAt, expiresAt])
}

model Student {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?       @unique
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName       String
  cpf            String
  cpfHash        String
  birthDate      DateTime
  phone          String
  address        String
  email          String
  photoUrl       String?
  enrollmentDate DateTime
  modality       String
  notes          String?
  status         StudentStatus @default(ATIVO)
  studentPlans   StudentPlan[]
  invoices       Invoice[]
  paymentTransactions PaymentTransaction[]
  assessments    PhysicalAssessment[]
  workoutPlans   WorkoutPlan[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@unique([organizationId, cpfHash])
  @@index([organizationId, status])
  @@index([organizationId, email])
}

model Plan {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  value          Decimal       @db.Decimal(10, 2)
  modality       String
  durationDays   Int
  dueDay         Int
  allowAssessments Boolean     @default(true)
  allowWorkouts    Boolean     @default(true)
  isActive       Boolean       @default(true)
  studentPlans   StudentPlan[]
  invoices       Invoice[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@index([organizationId, isActive])
}

model StudentPlan {
  id          String    @id @default(uuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  planId      String
  plan        Plan      @relation(fields: [planId], references: [id], onDelete: Restrict)
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([studentId, isActive])
}

model Invoice {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  studentId      String
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  planId         String?
  plan           Plan?         @relation(fields: [planId], references: [id], onDelete: SetNull)
  dueDate        DateTime
  paidAt         DateTime?
  amount         Decimal       @db.Decimal(10, 2)
  fineAmount     Decimal       @default(0) @db.Decimal(10, 2)
  interestAmount Decimal       @default(0) @db.Decimal(10, 2)
  totalPaid      Decimal       @default(0) @db.Decimal(10, 2)
  status         InvoiceStatus @default(PENDENTE)
  notes          String?
  paymentTransactions PaymentTransaction[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId, status, dueDate])
  @@index([studentId, dueDate])
}

model PaymentTransaction {
  id                  String                   @id @default(uuid())
  organizationId      String
  organization        Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceId           String
  invoice             Invoice                  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  studentId           String
  student             Student                  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  provider            PaymentProvider
  providerPaymentId   String?
  status              PaymentTransactionStatus @default(PENDING)
  amount              Decimal                  @db.Decimal(10, 2)
  qrCode              String?
  qrCodeBase64        String?
  copyPasteCode       String?
  expiresAt           DateTime?
  paidAt              DateTime?
  rawProviderResponse Json?
  rawWebhookPayload   Json?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([organizationId, status, createdAt])
  @@index([invoiceId, status])
  @@index([provider, providerPaymentId])
}

model FinancialSettings {
  id                         String       @id @default(uuid())
  organizationId             String       @unique
  organization               Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fixedFinePercentage        Decimal      @default(2) @db.Decimal(5, 2)
  dailyInterestPercentage    Decimal      @default(0.033) @db.Decimal(7, 4)
  monthlyInterestPercentage  Decimal      @default(1) @db.Decimal(5, 2)
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
}

model PhysicalAssessment {
  id                         String       @id @default(uuid())
  organizationId             String
  organization               Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  studentId                  String
  student                    Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  professorId                String?
  professor                  User?        @relation("ProfessorAssessments", fields: [professorId], references: [id], onDelete: SetNull)
  assessedAt                 DateTime
  startDate                  DateTime?
  trainingGoals              String[]     @default([])
  weightKg                   Decimal      @db.Decimal(6, 2)
  heightCm                   Decimal      @db.Decimal(6, 2)
  bmi                        Decimal      @db.Decimal(5, 2)
  bodyFatPercentage          Decimal?     @db.Decimal(5, 2)
  muscleMassKg               Decimal?     @db.Decimal(6, 2)
  abdominalCircumferenceCm   Decimal?     @db.Decimal(6, 2)
  armCircumferenceCm         Decimal?     @db.Decimal(6, 2)
  leftArmCircumferenceCm     Decimal?     @db.Decimal(6, 2)
  rightArmCircumferenceCm    Decimal?     @db.Decimal(6, 2)
  leftLegCircumferenceCm     Decimal?     @db.Decimal(6, 2)
  rightLegCircumferenceCm    Decimal?     @db.Decimal(6, 2)
  chestCircumferenceCm       Decimal?     @db.Decimal(6, 2)
  shoulderCircumferenceCm    Decimal?     @db.Decimal(6, 2)
  gluteCircumferenceCm       Decimal?     @db.Decimal(6, 2)
  leftCalfCircumferenceCm    Decimal?     @db.Decimal(6, 2)
  rightCalfCircumferenceCm   Decimal?     @db.Decimal(6, 2)
  waistCircumferenceCm       Decimal?     @db.Decimal(6, 2)
  hipCircumferenceCm         Decimal?     @db.Decimal(6, 2)
  bioimpedance               Json?
  anthropometry              Json?
  anthropometryMeasuredAt    DateTime?
  skinfolds                  Json?
  skinfoldsMeasuredAt        DateTime?
  physicalTests              Json?
  notes                      String?
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
  deletedAt                  DateTime?

  @@index([organizationId, studentId, assessedAt])
  @@index([organizationId, deletedAt])
}

model WorkoutPlan {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  professorId    String?
  professor      User?        @relation("ProfessorWorkoutPlans", fields: [professorId], references: [id], onDelete: SetNull)
  name           String
  goal           String
  startDate      DateTime
  endDate        DateTime?
  isActive       Boolean      @default(true)
  days           WorkoutDay[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@index([organizationId, studentId, isActive])
  @@index([organizationId, deletedAt])
}

model WorkoutDay {
  id            String          @id @default(uuid())
  workoutPlanId String
  workoutPlan   WorkoutPlan     @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  label         WorkoutDayLabel
  exercises     Exercise[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([workoutPlanId, label])
}

model Exercise {
  id           String     @id @default(uuid())
  workoutDayId String
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  libraryExerciseId String?
  libraryExercise   ExerciseLibrary? @relation(fields: [libraryExerciseId], references: [id], onDelete: SetNull)
  name         String
  sets         Int
  repetitions  String
  load         String?
  restSeconds  Int?
  notes        String?
  order        Int

  @@index([libraryExerciseId])
}

model ExerciseLibrary {
  id                    String            @id @default(uuid())
  organizationId        String
  organization          Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                  String
  category              String
  modality              String
  muscleGroup           String?
  description           String?
  executionInstructions String?
  commonMistakes        String?
  difficultyLevel       String
  mediaType             ExerciseMediaType
  mediaUrl              String
  thumbnailUrl          String?
  isActive              Boolean           @default(true)
  workoutExercises      Exercise[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  deletedAt             DateTime?

  @@index([organizationId, isActive, deletedAt])
  @@index([organizationId, modality, category])
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUserId    String?
  actor          User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  action         String
  entity         String
  entityId       String?
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId, entity, createdAt])
}
